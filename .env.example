# Copy to .env (gitignored) and fill in:  cp .env.example .env
# Every vm/ script sources vm/config.sh, which auto-loads this .env.

# --- Required ---
# GCP project to target. Required on purpose — we never use the ambient
# `gcloud config` project, so builds can't land in the wrong project.
PROJECT=reclamation-game

# Reusable Tailscale auth key: https://login.tailscale.com/admin/settings/keys
TAILSCALE_AUTHKEY=tskey-auth-xxxxxxxxxxxxxxxx

# Your phone's Tailscale IP (the phone is a tailnet node running adb in TCP mode).
# The VM connects straight to it (adb connect <ip>:5555) to install cloud-built APKs.
PHONE_TS_HOST=100.x.y.z

# Chrome Remote Desktop PIN (6+ digits) used by vm/crd-setup.sh when registering
# the VM as a CRD host. The registration persists across stop/start; a fresh node
# needs its own one-time (interactive) auth code.
CRD_PIN=123456

# Claude Code auth for the nodes (used on the VM). Two options — pick one:
#
#   A) Subscription OAuth token (recommended): leave both unset and let `create.sh`
#      mint one via `claude setup-token` on first run; it caches CLAUDE_CODE_OAUTH_TOKEN
#      here automatically and reuses it for every node (incl. fleet workers).
#   B) API key: set ANTHROPIC_API_KEY instead.
#
# Both are passed via per-instance metadata (NOT baked into the golden image).
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat...   # usually auto-filled by create.sh

# --- Android project (cloned + Gradle-warmed on each node at launch) ---
# HTTPS repo URL (token auth). On launch each node clones it into ~/work on the VM
# and warms the Gradle build in the background.
# GIT_REPO=https://github.com/you/your-android-app.git
# GIT_BRANCH=main
# GRADLE_WARM_TASK=assembleDebug     # what to run to warm the cache/daemon
# GitHub token for private clones. Auto-filled from `gh auth token` at create time if unset.
# GITHUB_TOKEN=ghp_...

# --- Android emulators (KVM) ---
# Emulators need nested virtualization, which on GCP is INTEL-ONLY (VT-x). Use an Intel
# machine (N2/C2/C3); AMD (N2D/C2D/C3D), E2, and Arm (T2A) do NOT expose it to the guest
# even with the flag. Nested virt adds no surcharge — you just pay the pricier machine.
# NESTED_VIRT=1
# MACHINE=n2-standard-4       # or n2-standard-8 for a multi-emulator grid; NOT n2d/e2/t2

# --- Optional overrides (defaults shown; uncomment to change) ---
# ZONE=us-west1-b
# INSTANCE=android-dev
# MACHINE=e2-standard-4
# DISK_GB=60
# IMAGE_FAMILY=ubuntu-2204-lts
# IMAGE_PROJECT=ubuntu-os-cloud
