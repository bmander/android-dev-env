// Example Tailscale ACL: let ONLY the android-dev nodes reach the phone's adb (tcp:5555).
// Paste/adapt in the admin console (Access Controls). Tag your phone + dev nodes to match.
{
  "tagOwners": {
    "tag:android-dev": ["autogroup:admin"],
    "tag:phone": ["autogroup:admin"]
  },
  "acls": [
    // Everything your tailnet already allows...
    { "action": "accept", "src": ["autogroup:member"], "dst": ["*:*"] },

    // ...plus: android-dev nodes may reach the phone's adb (nothing else new).
    {
      "action": "accept",
      "src": ["tag:android-dev"],
      "dst": ["tag:phone:5555"]
    }
  ]
}
